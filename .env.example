APP_NAME="Notification Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=app01-mysql
DB_PORT=3306
DB_DATABASE=notifications
DB_USERNAME=notif_user
DB_PASSWORD=notif_pass
DB_ROOT_PASSWORD=rootpassword

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=rabbitmq

REDIS_HOST=app01-redis
REDIS_PASSWORD=redis_pass
REDIS_PORT=6379

RABBITMQ_HOST=app01-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbit_user
RABBITMQ_PASSWORD=rabbit_pass
RABBITMQ_VHOST=notifications
RABBITMQ_QUEUE=notifications
RABBITMQ_EXCHANGE=notifications.direct
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_EXCHANGE_ROUTING_KEY=notifications

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@notifications.local"
MAIL_FROM_NAME="${APP_NAME}"

XDEBUG_MODE=debug
